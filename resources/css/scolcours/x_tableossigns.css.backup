@utility tos {
  & .cell-v-line:after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    border-left: 1px dashed #bbb;
    transform: translate(-50%);
    pointer-events: none;
  }

  & .cell-v-line-d:after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    border-left: 1px double #e00c0c;
    transform: translate(-50%);
    pointer-events: none;
  }

  & .cell-v-line {
    position: relative;
  }
}

@utility cell-v-line {
  .tos &:after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    border-left: 1px dashed #bbb;
    transform: translate(-50%);
    pointer-events: none;
  }

  .tos & {
    position: relative;
  }
}

@utility cell-v-line-d {
  .tos &:after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    border-left: 1px double #e00c0c;
    transform: translate(-50%);
    pointer-events: none;
  }
}
