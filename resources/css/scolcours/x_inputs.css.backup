.input {
  /* - Input design par défaut */
  @apply rounded-xs border-b outline-hidden focus:outline-hidden focus:border-b focus:border-blue-400 px-2 py-1;

  &textarea {
    @apply focus:border focus:border-blue-400;
  }

  label > &input {
    @apply rounded-none border-b outline-hidden focus:outline-hidden transition-all;
  }
}

.form-active {
  @apply bg-blue-50 border border-blue-500 transition;
}

.input-blue {
  label > &input {
    @apply border-blue-300 focus:border-blue-600;
  }
}

.input-red {
  label > &input {
    @apply border-red-300 focus:border-red-600;
  }
}

.form-input {
  /* Input wrapper */
  @apply relative inline-block;
  /* Input design */
  & > input {
    @apply w-full block
        appearance-none
        bg-transparent border-b-2
        focus:outline-hidden focus-within:border-blue-500;
  }
  & > input.success {
    @apply bg-green-50 focus-within:border-green-500;
  }
  /* Input's label design */
  & > label {
    @apply absolute top-0 pointer-events-none duration-300; /*TOOD: tailwindcss missing: origin-0*/
  }
  /* Underlying paragraph (error messages for example ) */
  & > p {
    @apply px-1 text-xs;
  }

  & > select {
    @apply w-full block
        appearance-none
        bg-transparent border-0 border-b-2 border-gray-200
        focus:outline-hidden focus-within:border-blue-500;
  }
}

.success {
  .form-input > &input {
    @apply bg-green-50 focus-within:border-green-500;
  }
}

.form-textarea {
  /* Textarea wrapper */
  @apply relative my-4;
  /* Textarea design */
  & > textarea {
    @apply w-full block
        appearance-none bg-transparent px-2 py-1
        border rounded-md
        focus:outline-hidden focus-within:border-blue-500;
  }
  /* Textarea's label */
  & > label {
    @apply absolute;
    top: -2rem !important;
  }
  & > p {
    @apply px-1 text-xs;
  }
}

.keyboard {
  & > .key-touch {
    touch-action: auto;
    @apply px-1 py-1 lg:px-3 lg:py-2 rounded-sm border hover:bg-blue-100 hover:border-blue-200 transition-colors;
  }

  & > .key {
    touch-action: none;
    @apply px-1 py-1 lg:px-3 lg:py-2 rounded-sm border hover:bg-blue-100 hover:border-blue-200 transition-colors;
  }

  & > .key-cmd {
    touch-action: none;
    @apply px-1 py-1 lg:px-3 lg:py-2 border rounded-lg transition-colors;
  }

  &.keyboard-sm > .key {
    @apply px-1 py-1;
  }

  &.keyboard-sm > .key .katex-display {
    @apply my-0;
  }
}

.key-touch {
  .keyboard > & {
    touch-action: auto;
    @apply px-1 py-1 lg:px-3 lg:py-2 rounded-sm border hover:bg-blue-100 hover:border-blue-200 transition-colors;
  }
}

.key {
  .keyboard > & {
    touch-action: none;
    @apply px-1 py-1 lg:px-3 lg:py-2 rounded-sm border hover:bg-blue-100 hover:border-blue-200 transition-colors;
  }

  .keyboard.keyboard-sm > & {
    @apply px-1 py-1;
  }

  .keyboard.keyboard-sm > & .katex-display {
    @apply my-0;
  }
}

.key-cmd {
  .keyboard > & {
    touch-action: none;
    @apply px-1 py-1 lg:px-3 lg:py-2 border rounded-lg transition-colors;
  }
}

.keyboard-sm {
  &.keyboard > .key {
    @apply px-1 py-1;
  }

  &.keyboard > .key .katex-display {
    @apply my-0;
  }
}

.katex-display {
  .keyboard.keyboard-sm > .key & {
    @apply my-0;
  }
}

@layer components {

    /* From control avec label qui se déplace */
    input:focus-within ~ label,
    input:not(:placeholder-shown) ~ label {
        @apply transform scale-75 -translate-y-6;
    }
    input:focus-within ~ label {
        @apply text-blue-600;
    }
}
