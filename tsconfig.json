{
  "compilerOptions": {
    "allowJs": true,
    "module": "ES2020",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": false,
    "isolatedModules": true,
    "target": "ES2020",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./resources/js/*"
      ]
    }
  },
  "include": [
    "resources/js/**/*.ts",
    "resources/js/**/*.d.ts",
    "resources/js/**/*.vue"
  ]
}
