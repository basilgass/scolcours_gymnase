{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": [
			"ES6",
			"DOM",
			"ES7",
			"ES2015.Core",
			"ES2019",
			"ES2020",
			"ES2021",
			"ES2022",
			"ESNext"
		],
		"strict": false,
		"jsx": "preserve",
		"resolveJsonModule": true,
		"allowJs": true,
		"noEmit": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"allowImportingTsExtensions": true,
		"paths": {
			"@/*": [
				"./resources/js/*"
			]
		}
	},
	"include": [
		"resources/js/**/*.ts",
		"resources/js/**/*.d.ts",
		"resources/js/**/*.vue"
	],
	"exclude": [
		"node_modules"
	]
}